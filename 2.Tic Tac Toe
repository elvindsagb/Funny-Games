//code for tic tac toe

def print_board(board):
    print("\n")
    for i in range(3):
        print(" | ".join(board[i]))
        if i < 2:
            print("--+---+--")
    print("\n")


def check_winner(board, symbol):
    # Rows. 
    for row in board:
        if all(cell == symbol for cell in row):
            return True

    # Columns
    for col in range(3):
        if all(board[row][col] == symbol for row in range(3)):
            return True

    # Diagonals
    if all(board[i][i] == symbol for i in range(3)):
        return True
    if all(board[i][2 - i] == symbol for i in range(3)):
        return True

    return False


def is_draw(board):
    return all(cell != " " for row in board for cell in row)


# Initialize board
board = [[" " for _ in range(3)] for _ in range(3)]

# Player input
player1 = input("Enter Player 1 name (X): ")
player2 = input("Enter Player 2 name (O): ")

players = [(player1, "X"), (player2, "O")]

turn = 0

print("\n🎮 Tic-Tac-Toe Game Start!\n")
print_board(board)

while True:
    name, symbol = players[turn % 2]

    print(f"{name}'s turn ({symbol})")

    try:
        row = int(input("Enter row (1-3): ")) - 1
        col = int(input("Enter column (1-3): ")) - 1
    except ValueError:
        print("Invalid input! Please enter numbers only.\n")
        continue

    # Validate move
    if row not in range(3) or col not in range(3):
        print("Invalid position! Try again.\n")
        continue

    if board[row][col] != " ":
        print("Cell already occupied! Try again.\n")
        continue

    # Place symbol
    board[row][col] = symbol
    print_board(board)

    # Check winner
    if check_winner(board, symbol):
        print(f"🏆 {name} wins the game!")
        break

    # Check draw
    if is_draw(board):
        print("🤝 It's a draw!")
        break

    turn += 1
